# Base de datos (Neon / Supabase / cualquier PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better Auth — genera el secret con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=cambia_esto_por_un_secreto_seguro
BETTER_AUTH_URL=https://tu-dominio.up.railway.app

# URL del frontend (para CORS y trustedOrigins)
APP_URL=https://tu-dominio.up.railway.app
FRONTEND_URL=https://tu-frontend.vercel.app

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# Google Gemini
GEMINI_API_KEY=tu_gemini_api_key

# Servidor
PORT=3000
